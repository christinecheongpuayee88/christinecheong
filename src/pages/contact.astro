---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact"
  description="Get in touch with Christine Cheong — for course enquiries, executive education delivery, speaking opportunities, and general questions."
>

  <section class="page-header">
    <div class="wrap">
      <p class="eyebrow anim anim-1">Contact</p>
      <h1 class="page-header__h1 anim anim-2">Get In Touch</h1>
      <p class="page-header__sub anim anim-3">
        I respond to all enquiries within 2 business days.
      </p>
    </div>
  </section>

  <hr class="hr" />

  <section class="section">
    <div class="wrap contact-layout">

      <!-- Form -->
      <div class="contact-form-wrap">
        <form
          action="https://formsubmit.co/ajax/christinecheong88@gmail.com"
          method="POST"
          id="contact-form"
          class="contact-form"
        >
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />

          <div class="field">
            <label for="name">Your name</label>
            <input type="text" id="name" name="name" required placeholder="Jane Smith" />
          </div>

          <div class="field">
            <label for="email">Email address</label>
            <input type="email" id="email" name="email" required placeholder="jane@organisation.com" />
          </div>

          <div class="field">
            <label for="subject">What is this about?</label>
            <select id="subject" name="subject">
              <option value="">Select a topic</option>
              <option>Course enquiry (individual)</option>
              <option>Course enquiry (organisational)</option>
              <option>Executive education delivery</option>
              <option>Speaking or workshop opportunity</option>
              <option>General question</option>
            </select>
          </div>

          <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="6" required
              placeholder="Tell me what you're looking for..."></textarea>
          </div>

          <button type="submit" class="btn btn--primary submit-btn" id="submit-btn">
            Send Message
          </button>

          <p class="form-note" id="form-success" hidden>
            ✓ Message sent. I'll be in touch within 2 business days.
          </p>
          <p class="form-note form-note--error" id="form-error" hidden>
            Something went wrong — please email me directly at
            <a href="mailto:christinecheong88@gmail.com">christinecheong88@gmail.com</a>.
          </p>
        </form>
      </div>

      <!-- Sidebar info -->
      <aside class="contact-sidebar">
        <div class="info-card">
          <p class="info-card__label">Direct Email</p>
          <a href="mailto:christinecheong88@gmail.com" class="info-card__email">
            christinecheong88@gmail.com
          </a>
        </div>

        <div class="info-card">
          <p class="info-card__label">Things I'm Happy to Discuss</p>
          <ul class="info-card__list">
            <li>Course enquiries (individual or organisational)</li>
            <li>Executive education delivery</li>
            <li>Speaking or workshop opportunities</li>
            <li>General questions about data science education</li>
          </ul>
        </div>

        <div class="info-card">
          <p class="info-card__label">Response Time</p>
          <p style="font-size:15px;color:var(--text-2);">
            I aim to reply to all enquiries within 2 business days.
          </p>
        </div>
      </aside>

    </div>
  </section>

</Base>

<style>
  .page-header {
    padding: var(--sp-10) 0 var(--sp-8);
    background: var(--surface);
  }
  .page-header__h1 {
    font-size: clamp(40px, 5vw, 64px);
    margin-top: var(--sp-3);
    letter-spacing: -.02em;
  }
  .page-header__sub { font-size: 18px; color: var(--text-2); margin-top: var(--sp-3); }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--sp-10);
    align-items: start;
  }

  /* Form */
  .contact-form { display: flex; flex-direction: column; gap: var(--sp-5); }

  .field { display: flex; flex-direction: column; gap: var(--sp-2); }
  .field label {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }
  .field input,
  .field select,
  .field textarea {
    font-family: var(--sans);
    font-size: 15px;
    color: var(--text);
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--r);
    padding: 12px 14px;
    transition: border-color var(--ease), box-shadow var(--ease);
    outline: none;
    width: 100%;
    appearance: none;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(45,91,227,.12);
  }
  .field textarea { resize: vertical; min-height: 140px; }
  .field input::placeholder,
  .field textarea::placeholder { color: var(--text-3); }

  .submit-btn { align-self: flex-start; }

  .form-note {
    font-size: 14px;
    color: var(--text-2);
    padding: var(--sp-3) var(--sp-4);
    background: var(--surface);
    border-radius: var(--r);
    border-left: 3px solid var(--accent);
  }
  .form-note--error { border-color: #E53935; background: #FFF5F5; }
  .form-note a { color: var(--accent); text-decoration: underline; }

  /* Sidebar */
  .contact-sidebar { display: flex; flex-direction: column; gap: var(--sp-4); }
  .info-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: var(--sp-5) var(--sp-6);
  }
  .info-card__label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: var(--sp-3);
  }
  .info-card__email {
    font-size: 15px;
    font-weight: 500;
    color: var(--accent);
    word-break: break-all;
    transition: color var(--ease);
  }
  .info-card__email:hover { color: var(--accent-dark); }
  .info-card__list { display: flex; flex-direction: column; gap: var(--sp-2); }
  .info-card__list li {
    font-size: 14px;
    color: var(--text-2);
    padding: var(--sp-2) 0;
    border-bottom: 1px solid var(--border);
    line-height: 1.5;
  }
  .info-card__list li:last-child { border-bottom: none; }

  @media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; }
    .contact-sidebar { order: -1; }
  }
</style>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const btn     = document.getElementById('submit-btn');
  const success = document.getElementById('form-success');
  const error   = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn) return;

    btn.textContent = 'Sending…';
    (btn as HTMLButtonElement).disabled = true;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      });

      if (res.ok) {
        form.reset();
        success?.removeAttribute('hidden');
        btn.textContent = 'Message Sent';
      } else {
        throw new Error('Non-OK response');
      }
    } catch {
      error?.removeAttribute('hidden');
      btn.textContent = 'Send Message';
      (btn as HTMLButtonElement).disabled = false;
    }
  });
</script>
