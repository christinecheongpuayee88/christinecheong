---
import Base from '../layouts/Base.astro';
---

<Base
  title="Christine Cheong"
  description="Christine Cheong teaches data science to university students and executive education participants — bridging the gap between theory and real-world decisions."
>

  <!-- ═══════════════════════════════════════════ HERO -->
  <section class="hero">
    <div class="wrap hero__grid">

      <!-- Left: text -->
      <div class="hero__copy">
        <p class="eyebrow anim anim-1">Data Science Educator &nbsp;&middot;&nbsp; NUS-ISS</p>
        <h1 class="hero__h1 anim anim-2">
          Teaching Data Science<br />
          to the People<br />
          Who Need It Most
        </h1>
        <p class="hero__body anim anim-3">
          Bridging the gap between theory and the real-world decisions
          that matter to organisations &mdash; for students building
          foundations and professionals stepping up.
        </p>
        <div class="hero__actions anim anim-4">
          <a href="/contact" class="btn btn--primary">Get In Touch</a>
          <a href="/courses" class="btn btn--ghost">View Courses</a>
        </div>
      </div>

      <!-- Right: data-inspired SVG visual -->
      <div class="hero__visual anim anim-5" aria-hidden="true">
        <svg viewBox="0 0 360 320" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Grid lines -->
          <line x1="60"  y1="20" x2="60"  y2="280" stroke="#E7E5E0" stroke-width="1"/>
          <line x1="120" y1="20" x2="120" y2="280" stroke="#E7E5E0" stroke-width="1"/>
          <line x1="180" y1="20" x2="180" y2="280" stroke="#E7E5E0" stroke-width="1"/>
          <line x1="240" y1="20" x2="240" y2="280" stroke="#E7E5E0" stroke-width="1"/>
          <line x1="300" y1="20" x2="300" y2="280" stroke="#E7E5E0" stroke-width="1"/>
          <line x1="30" y1="60"  x2="330" y2="60"  stroke="#E7E5E0" stroke-width="1"/>
          <line x1="30" y1="120" x2="330" y2="120" stroke="#E7E5E0" stroke-width="1"/>
          <line x1="30" y1="180" x2="330" y2="180" stroke="#E7E5E0" stroke-width="1"/>
          <line x1="30" y1="240" x2="330" y2="240" stroke="#E7E5E0" stroke-width="1"/>
          <!-- Axes -->
          <line x1="45" y1="20"  x2="45"  y2="275" stroke="#C0BCB5" stroke-width="1.5"/>
          <line x1="45" y1="275" x2="330" y2="275" stroke="#C0BCB5" stroke-width="1.5"/>
          <!-- Trend line -->
          <line x1="65" y1="248" x2="310" y2="72" stroke="#2D5BE3" stroke-width="2"
                stroke-dasharray="7 4" opacity="0.45"/>
          <!-- Data points -->
          <circle cx="80"  cy="240" r="5"   fill="#A8A29E" opacity=".65"/>
          <circle cx="102" cy="220" r="4"   fill="#78716C" opacity=".6"/>
          <circle cx="118" cy="208" r="6.5" fill="#A8A29E" opacity=".55"/>
          <circle cx="135" cy="195" r="4"   fill="#2D5BE3" opacity=".45"/>
          <circle cx="152" cy="183" r="7"   fill="#2D5BE3" opacity=".65"/>
          <circle cx="168" cy="166" r="4"   fill="#78716C" opacity=".6"/>
          <circle cx="185" cy="155" r="5"   fill="#A8A29E" opacity=".6"/>
          <circle cx="200" cy="140" r="4"   fill="#2D5BE3" opacity=".5"/>
          <circle cx="218" cy="128" r="6"   fill="#78716C" opacity=".65"/>
          <circle cx="235" cy="115" r="4.5" fill="#A8A29E" opacity=".6"/>
          <circle cx="252" cy="100" r="5"   fill="#2D5BE3" opacity=".75"/>
          <circle cx="268" cy="88"  r="7"   fill="#2D5BE3" opacity=".9"/>
          <circle cx="290" cy="76"  r="4"   fill="#2D5BE3" opacity=".7"/>
          <!-- Highlight ring on last point -->
          <circle cx="268" cy="88" r="12" stroke="#2D5BE3" stroke-width="1.5" opacity=".25"/>
          <!-- Axis tick labels (decorative) -->
          <text x="32" y="278" font-family="Plus Jakarta Sans,sans-serif" font-size="9" fill="#A8A29E">0</text>
          <text x="38" y="243" font-family="Plus Jakarta Sans,sans-serif" font-size="9" fill="#A8A29E">25</text>
          <text x="38" y="183" font-family="Plus Jakarta Sans,sans-serif" font-size="9" fill="#A8A29E">50</text>
          <text x="38" y="123" font-family="Plus Jakarta Sans,sans-serif" font-size="9" fill="#A8A29E">75</text>
          <text x="32" y="63"  font-family="Plus Jakarta Sans,sans-serif" font-size="9" fill="#A8A29E">100</text>
          <!-- Chart label -->
          <text x="60" y="16" font-family="Plus Jakarta Sans,sans-serif" font-size="10"
                font-weight="600" fill="#A8A29E" letter-spacing=".06em">SKILL PROGRESSION OVER TIME</text>
        </svg>
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- ═══════════════════════════════════════════ WHAT I DO -->
  <section class="section what">
    <div class="wrap what__inner">
      <p class="eyebrow">What I Do</p>
      <h2 class="what__h2">
        Making data science click<br />
        in the classroom and the boardroom
      </h2>
      <p class="what__body">
        I teach data science — in universities, in corporate training rooms, and everywhere in between.
        Whether you're a student building your analytical foundations or a working professional who
        needs to lead data projects, my goal is the same: make data science feel less like a subject
        and more like a skill you actually own.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ WHO I WORK WITH -->
  <section class="section audience" style="background:var(--surface);">
    <div class="wrap">
      <p class="eyebrow" style="text-align:center;margin-bottom:var(--sp-7);">Who I Work With</p>
      <div class="audience__grid">

        <div class="audience__card">
          <div class="audience__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 14l9-5-9-5-9 5 9 5z"/>
              <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055
                       a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
            </svg>
          </div>
          <h3>University Students</h3>
          <p>
            Learning the fundamentals of data science, statistics, and programming in a structured
            academic setting &mdash; with an emphasis on applying what you learn to real problems,
            not just passing exams.
          </p>
        </div>

        <div class="audience__card">
          <div class="audience__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2"/>
              <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
              <line x1="12" y1="12" x2="12" y2="16"/>
              <line x1="10" y1="14" x2="14" y2="14"/>
            </svg>
          </div>
          <h3>Executive Education Participants</h3>
          <p>
            Working professionals and leaders who need to understand data science well enough to
            lead projects, ask the right questions, and make better decisions &mdash; without
            necessarily becoming engineers themselves.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ WHY LEARN WITH ME -->
  <section class="section why">
    <div class="wrap why__inner">
      <div class="why__left">
        <p class="eyebrow">Why Learn With Me</p>
        <h2>Experience that shows<br />in every session</h2>
        <p style="color:var(--text-2);margin-top:var(--sp-5);max-width:36ch;">
          I bring hands-on experience to every class &mdash; not just as an educator,
          but as someone who has worked with data in professional contexts.
        </p>
        <a href="/about" class="btn btn--ghost" style="margin-top:var(--sp-6);">
          Read My Story
        </a>
      </div>

      <ul class="why__list">
        <li class="why__item">
          <span class="why__num">01</span>
          <div>
            <strong>Curriculum designed around real-world application</strong>
            <p>Fewer abstract examples, more situations your team or organisation will actually recognise.</p>
          </div>
        </li>
        <li class="why__item">
          <span class="why__num">02</span>
          <div>
            <strong>Clear explanations of complex concepts</strong>
            <p>No unnecessary jargon. No hand-waving. Just honest, patient teaching.</p>
          </div>
        </li>
        <li class="why__item">
          <span class="why__num">03</span>
          <div>
            <strong>Experience across academic and corporate settings</strong>
            <p>I understand what students need and what executives actually ask.</p>
          </div>
        </li>
        <li class="why__item">
          <span class="why__num">04</span>
          <div>
            <strong>Practical exercises that build genuine confidence</strong>
            <p>Not just exam performance &mdash; skills that transfer to the workplace.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ TESTIMONIALS -->
  <section class="section testimonials" style="background:var(--surface);">
    <div class="wrap">
      <p class="eyebrow" style="text-align:center;margin-bottom:var(--sp-7);">What Participants Say</p>
      <div class="testimonials__grid">

        <blockquote class="testimonial">
          <p class="testimonial__quote">
            &ldquo;Christine has a rare ability to explain technical concepts clearly without
            oversimplifying them. I left the programme actually understanding how to apply
            what I&rsquo;d learned.&rdquo;
          </p>
          <footer class="testimonial__attr">
            <span class="testimonial__name">[Name, Title]</span>
            <span class="testimonial__org">[Organisation]</span>
          </footer>
        </blockquote>

        <blockquote class="testimonial">
          <p class="testimonial__quote">
            &ldquo;One of the best instructors I&rsquo;ve encountered in executive education.
            Engaging, knowledgeable, and genuinely invested in whether participants
            understand the material.&rdquo;
          </p>
          <footer class="testimonial__attr">
            <span class="testimonial__name">[Name, Title]</span>
            <span class="testimonial__org">[Programme]</span>
          </footer>
        </blockquote>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ FINAL CTA -->
  <section class="section cta-band">
    <div class="wrap cta-band__inner">
      <h2>Ready to get started?</h2>
      <p>
        Whether you&rsquo;re a student, a programme coordinator, or an organisation
        exploring executive education options &mdash; I&rsquo;d love to hear from you.
      </p>
      <a href="/contact" class="btn btn--primary">Get In Touch</a>
    </div>
  </section>

</Base>

<style>
  /* ── Hero ──────────────────────────────────────────────────── */
  .hero {
    min-height: calc(92svh - var(--nav-h));
    display: flex;
    align-items: center;
    padding: var(--sp-10) 0;
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-8);
    align-items: center;
  }
  .hero__copy { display: flex; flex-direction: column; gap: var(--sp-5); }
  .eyebrow    { margin-bottom: calc(-1 * var(--sp-2)); }

  .hero__h1 {
    font-size: clamp(40px, 5.5vw, 68px);
    line-height: 1.1;
    letter-spacing: -.02em;
  }
  .hero__body {
    font-size: 18px;
    color: var(--text-2);
    max-width: 42ch;
    line-height: 1.7;
  }
  .hero__actions { display: flex; gap: var(--sp-3); flex-wrap: wrap; }

  .hero__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero__visual svg {
    width: 100%;
    max-width: 420px;
    filter: drop-shadow(0 2px 24px rgba(0,0,0,.04));
  }

  /* ── What I Do ─────────────────────────────────────────────── */
  .what__inner {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--sp-7) var(--sp-8);
    align-items: start;
  }
  .what__h2   { font-size: clamp(28px, 3.5vw, 42px); }
  .what__body {
    color: var(--text-2);
    font-size: 17px;
    line-height: 1.8;
    max-width: 60ch;
    grid-column: 2;
  }

  /* ── Audience ───────────────────────────────────────────────── */
  .audience__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-5);
  }
  .audience__card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: var(--sp-7);
  }
  .audience__icon {
    color: var(--accent);
    margin-bottom: var(--sp-4);
  }
  .audience__card h3 {
    font-size: 22px;
    margin-bottom: var(--sp-4);
  }
  .audience__card p { color: var(--text-2); font-size: 15px; line-height: 1.8; }

  /* ── Why Learn ──────────────────────────────────────────────── */
  .why__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-8);
    align-items: start;
  }
  .why__left h2 { font-size: clamp(28px, 3vw, 40px); margin-top: var(--sp-4); }

  .why__list { display: flex; flex-direction: column; gap: var(--sp-6); }
  .why__item {
    display: flex;
    gap: var(--sp-5);
    padding-top: var(--sp-5);
    border-top: 1px solid var(--border);
  }
  .why__item:first-child { border-top: none; padding-top: 0; }
  .why__num {
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: .05em;
    flex-shrink: 0;
    padding-top: 2px;
    width: 24px;
  }
  .why__item strong { display: block; font-weight: 600; font-size: 15px; margin-bottom: var(--sp-1); }
  .why__item p { color: var(--text-2); font-size: 14px; }

  /* ── Testimonials ───────────────────────────────────────────── */
  .testimonials__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-5);
  }
  .testimonial {
    background: var(--bg);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
    padding: var(--sp-6) var(--sp-7);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .testimonial__quote {
    font-family: var(--serif);
    font-size: 18px;
    font-style: italic;
    line-height: 1.6;
    color: var(--text);
  }
  .testimonial__attr { display: flex; flex-direction: column; gap: 2px; }
  .testimonial__name { font-size: 14px; font-weight: 600; color: var(--text); }
  .testimonial__org  { font-size: 13px; color: var(--text-3); }

  /* ── CTA Band ───────────────────────────────────────────────── */
  .cta-band { background: var(--accent-light); border-top: 1px solid #D6DFF7; }
  .cta-band__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--sp-5);
  }
  .cta-band h2  { font-size: clamp(28px, 3.5vw, 44px); }
  .cta-band p   { color: var(--text-2); font-size: 17px; max-width: 52ch; }

  /* ── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero__grid         { grid-template-columns: 1fr; }
    .hero__visual       { display: none; }
    .what__inner        { grid-template-columns: 1fr; }
    .what__body         { grid-column: 1; }
    .audience__grid     { grid-template-columns: 1fr; }
    .why__inner         { grid-template-columns: 1fr; }
    .testimonials__grid { grid-template-columns: 1fr; }
  }
</style>
